#(=> Strype:1:std
'''An example tutorial with instructional steps'''
#(=> Section:Tutorial
steps:
- title: "Welcome!"
  description: "This is a tutorial on Strype"
- title: "First Steps"
  description: "Use your keyboard to create a frame, we are looking for a function call!"
- title: "Insert string"
  description: "Insert the string \"Hello world!\" in the frame, to be printed"
- title: "Run the project"
  description: "Use the console to run your project"
- title: "Finish"
  description: "Congratulations, you have finished the project!"
#(=> Section:Imports
#(=> Section:Definitions
#(=> Section:Main
print("Hello world!") 
#(=> Section:End
